SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-domain.com,localhost,127.0.0.1

# Database (Docker Compose ichida db konteyner nomi ishlatiladi)
DB_NAME=moduldb
DB_USER=postgres
DB_PASSWORD=your-strong-password
DB_HOST=db
DB_PORT=5432

# Or use DATABASE_URL instead:
# DATABASE_URL=postgres://user:password@db:5432/moduldb

# CORS — har bir teacher ning domeni bazadan olinadi.
# Bu yerga faqat development uchun yoki umumiy domen yozing.
CORS_ALLOWED_ORIGINS=https://your-frontend.com

# CSRF
CSRF_TRUSTED_ORIGINS=https://your-domain.com
