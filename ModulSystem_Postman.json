{
    "info": {
        "_postman_id": "5fa23d6a-5c1a-4ea8-aa92-747d81283d58",
        "name": "ModulSystem API",
        "description": "Django REST API endpoints for ModulSystem.\n\nFirst, ru \"Teacher Login\" request. It will automatically save your `api_token` into Postman variables and apply it to all other requests!",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Teacher Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "let jsonData = pm.response.json();",
                                    "if (jsonData.api_token) {",
                                    "    pm.collectionVariables.set(\"api_token\", jsonData.api_token);",
                                    "    console.log(\"Saved new Token: \" + jsonData.api_token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"teacher1@example.com\",\n    \"password\": \"test123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/teachers/login/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "teachers",
                                "login",
                                ""
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Current Teacher (Me)",
                    "request": {
                        "auth": {
                            "type": "apikey",
                            "apikey": [
                                {
                                    "key": "value",
                                    "value": "Token {{api_token}}",
                                    "type": "string"
                                },
                                {
                                    "key": "key",
                                    "value": "Authorization",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/teachers/me/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "teachers",
                                "me",
                                ""
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
